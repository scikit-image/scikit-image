python_sources = [
    '_draw.py',
    '__init__.pyi',
    '__init__.py',
    '_polygon2mask.py',
    'draw3d.py',
    'draw_nd.py',
    '_random_shapes.py',
    'draw.py',
]

py3.install_sources(
  python_sources,
  pure: false,          # Will be installed next to binaries
  subdir: 'skimage/draw'  # Folder relative to site-packages to install to
)
