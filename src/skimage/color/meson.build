python_sources = [
    '__init__.pyi',
    'colorlabel.py',
    'colorconv.py',
    '__init__.py',
    'delta_e.py',
    'adapt_rgb.py',
    'rgb_colors.py',
]

py3.install_sources(
  python_sources,
  pure: false,          # Will be installed next to binaries
  subdir: 'skimage/color'  # Folder relative to site-packages to install to
)
